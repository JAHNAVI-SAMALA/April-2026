from collections import deque
from typing import List

class Solution:
    def hasValidPath(self, grid: List[List[int]]) -> bool:
        m, n = len(grid), len(grid[0])

        dirs = {
            1: [(0, -1), (0, 1)],
            2: [(-1, 0), (1, 0)],
            3: [(0, -1), (1, 0)],
            4: [(0, 1), (1, 0)],
            5: [(0, -1), (-1, 0)],
            6: [(0, 1), (-1, 0)]
        }

        q = deque([(0, 0)])
        visited = set([(0, 0)])

        while q:
            r, c = q.popleft()

            if (r, c) == (m - 1, n - 1):
                return True

            for dr, dc in dirs[grid[r][c]]:
                nr, nc = r + dr, c + dc

                if 0 <= nr < m and 0 <= nc < n and (nr, nc) not in visited:
                    # critical check: reverse connection must exist
                    if (-dr, -dc) in dirs[grid[nr][nc]]:
                        visited.add((nr, nc))
                        q.append((nr, nc))

        return False
